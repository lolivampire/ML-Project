# .env.example — boleh commit, jangan commit .env.dev atau .env.prod

# Application
APP_NAME=ml-risk-api
DEBUG=false
LOG_LEVEL=info

# API Security
API_KEY=your-api-key-here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Database (jika ada)
DB_URL=postgresql://user:password@host:5432/dbname

# Model
MODEL_PATH=/app/models/risk_model.joblib